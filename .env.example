# OpenWA Configuration
OPENWA_BASE_URL=http://localhost:3000
OPENWA_API_KEY=your_openwa_api_key_here
OPENWA_SESSION_ID=default

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# School Kiosk Face Engine
KIOSK_FACE_DRIVER=browser
KIOSK_FACE_SERVICE_URL=http://127.0.0.1:8800
KIOSK_FACE_SERVICE_KEY=
KIOSK_FACE_SERVICE_TIMEOUT=20
KIOSK_FACE_SERVICE_CONNECT_TIMEOUT=5
KIOSK_FACE_CAPTURE_FRAME_COUNT=6
KIOSK_FACE_CAPTURE_MAX_FRAMES=8
